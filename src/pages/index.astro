<script>
	// Scroll-reveal
	const reveals = document.querySelectorAll(".reveal");
	const io = new IntersectionObserver(
		(entries) => {
			entries.forEach((e, i) => {
				if (e.isIntersecting) {
					setTimeout(() => e.target.classList.add("in"), i * 90);
					io.unobserve(e.target);
				}
			});
		},
		{ threshold: 0.08 },
	);
	reveals.forEach((el) => io.observe(el));

	// Counter effect for stats values
	const counters = document.querySelectorAll<HTMLElement>(".js-counter");
	const counterFrames = new WeakMap<HTMLElement, number>();
	const parseCounterTarget = (rawValue: string) => {
		const cleaned = rawValue.replace(/,/g, "");
		const match = cleaned.match(/-?\d+(\.\d+)?/);
		if (!match) {
			return null;
		}
		const numberText = match[0];
		const startIndex = match.index ?? 0;
		return {
			number: Number(numberText),
			prefix: cleaned.slice(0, startIndex),
			suffix: cleaned.slice(startIndex + numberText.length),
			decimals: numberText.includes(".")
				? numberText.split(".")[1].length
				: 0,
		};
	};

	const animateCounter = (element: HTMLElement, delay = 0) => {
		const targetText =
			element.dataset.target ?? element.textContent?.trim() ?? "";
		const parsed = parseCounterTarget(targetText);
		if (!parsed) {
			return;
		}

		const existingFrame = counterFrames.get(element);
		if (existingFrame) {
			cancelAnimationFrame(existingFrame);
		}

		element.textContent = `${parsed.prefix}0${parsed.suffix}`;
		const duration = 1400;
		const startTime = performance.now() + delay;

		const tick = (now: number) => {
			if (now < startTime) {
				requestAnimationFrame(tick);
				return;
			}
			const progress = Math.min((now - startTime) / duration, 1);
			const eased = 1 - Math.pow(1 - progress, 3);
			const currentValue = parsed.number * eased;
			const displayed =
				parsed.decimals > 0
					? currentValue.toFixed(parsed.decimals)
					: Math.round(currentValue).toLocaleString("en-US");

			element.textContent = `${parsed.prefix}${displayed}${parsed.suffix}`;
			if (progress < 1) {
				const nextFrame = requestAnimationFrame(tick);
				counterFrames.set(element, nextFrame);
			} else {
				element.textContent = targetText;
				counterFrames.delete(element);
			}
		};

		const firstFrame = requestAnimationFrame(tick);
		counterFrames.set(element, firstFrame);
	};

	let statsInView = false;
	const statsObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					if (!statsInView) {
						counters.forEach((counter, index) =>
							animateCounter(counter, index * 140),
						);
						statsInView = true;
					}
					return;
				}

				statsInView = false;
			});
		},
		{ threshold: 0.35 },
	);

	const statsStrip = document.querySelector(".stats-strip");
	if (statsStrip && counters.length > 0) {
		statsObserver.observe(statsStrip);
	}
</script>
