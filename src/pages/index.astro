---
import Layout from "../layouts/Layout.astro";
import ServerStatus from "../components/ServerStatus.astro";
import sfImage from "../assets/imgs/rss3_dark_3.png";

const title = "Reborn Racing";
const description =
	"Reborn Racing — Season 4 launches April 27th. 24 drivers, 10 circuits, and per-race rewards for the podium. The most competitive season yet.";

const stats = [
	{ value: "30+", label: "Races Hosted" },
	{ value: "75+", label: "Registered Drivers" },
	{ value: "15+", label: "Podium Finishers" },
	{ value: "~30", label: "Reports Closed" },
	{ value: "3", label: "Seasons Completed" },
];

const aboutFacts = [
	{ label: "Founded", value: "May 2025" },
	{ label: "Platform", value: "PC" },
	{ label: "Entry", value: "Open To Everyone" },
];

const getFlagUrl = (countryCode: string) =>
	`https://flagcdn.com/w40/${countryCode.toLowerCase()}.png`;

const calendar = [
	{
		round: "01",
		date: "Mon 27 Apr",
		countryCode: "BH",
		name: "Bahrain International Circuit",
		country: "Sakhir, Bahrain",
		badge: "opener",
	},
	{
		round: "02",
		date: "Mon 04 May",
		countryCode: "IT",
		name: "Autodromo Nazionale Monza",
		country: "Monza, Italy",
		badge: "",
	},
	{
		round: "03",
		date: "Mon 18 May",
		countryCode: "AU",
		name: "Phillip Island Grand Prix Circuit",
		country: "Phillip Island, Australia",
		badge: "",
	},
	{
		round: "04",
		date: "Mon 25 May",
		countryCode: "GB",
		name: "Silverstone Circuit",
		country: "Northamptonshire, UK",
		badge: "",
	},
	{
		round: "05",
		date: "Mon 08 Jun",
		countryCode: "JP",
		name: "Okayama International Circuit",
		country: "Okayama, Japan",
		badge: "",
	},
	{
		round: "06",
		date: "Mon 15 Jun",
		countryCode: "BE",
		name: "Circuit de Spa-Francorchamps",
		country: "Stavelot, Belgium",
		badge: "",
	},
	{
		round: "07",
		date: "Mon 29 Jun",
		countryCode: "MY",
		name: "Sepang International Circuit",
		country: "Sepang, Malaysia",
		badge: "",
	},
	{
		round: "08",
		date: "Mon 06 Jul",
		countryCode: "AT",
		name: "Red Bull Ring",
		country: "Spielberg, Austria",
		badge: "",
	},
	{
		round: "09",
		date: "Mon 20 Jul",
		countryCode: "PT",
		name: "Autodromo Internacional do Algarve",
		country: "Portimao, Portugal",
		badge: "",
	},
	{
		round: "10",
		date: "Mon 27 Jul",
		countryCode: "BR",
		name: "Autodromo Jose Carlos Pace",
		country: "Interlagos, Brazil",
		badge: "finale",
	},
];

const format = [
	{
		phase: "Qualifying",
		time: "15 min",
		start: "21:00 ca.",
	},
	{
		phase: "Race",
		time: "45 min ca.",
		distance: "150 km",
		start: "21:15 ca.",
	},
	{
		phase: "Inverted Grid Sprint",
		time: "20 min ca.",
		distance: "75 km",
		start: "22:00 ca.",
	},
];
const calendarLeft = calendar.slice(0, 5);
const calendarRight = calendar.slice(5, 10);

const carFeatures = ["High downforce", "Fixed setup", "DRS MODE"];
---

<Layout title={title} description={description}>
	<!-- ══════════════════════════ NAV ══════════════════════════ -->
	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="nav-brand">
				<span class="nav-brand-name">
					<span class="nav-brand-reborn">Reborn</span>
					<span class="nav-brand-racing">Racing</span>
				</span>
			</a>
			<button
				class="mobile-toggle"
				aria-label="Toggle Menu"
				aria-expanded="false"
			>
				<span class="hamburger"></span>
			</button>
			<div class="nav-links">
				<a href="#about" class="nav-link">About Us</a>
				<a href="#car" class="nav-link">Car</a>
				<a href="#format" class="nav-link">Format</a>
				<a href="#calendar" class="nav-link">Calendar</a>
				<ServerStatus />
				<a href="#join" class="nav-cta">Join Season 4</a>
			</div>
		</div>
	</nav>

	<!-- ══════════════════════════ HERO ══════════════════════════ -->
	<section class="hero">
		<div class="hero-bg" aria-hidden="true">
			<div class="hero-glow"></div>
			<div class="hero-stripe"></div>
			<!-- Speed lines -->
			<div class="hero-lines"></div>
		</div>

		<div class="hero-content wrap">
			<p class="hero-eyebrow label">
				Assetto Corsa · Sim Racing League · Season 4
			</p>

			<h1 class="hero-title">
				<span class="hero-title-reborn">Reborn</span>
				<span class="hero-title-racing">Racing</span>
			</h1>

			<div class="hero-highlight">
				<p class="hero-metrics">
					<span>24 Drivers</span>
					<span>10 Circuits</span>
					<span class="hero-metrics-champion"
						><span>1 Champion</span></span
					>
				</p>
				<p class="hero-launch-line">
					<span class="hero-launch-label">Season 4 Launches</span>
					<span class="hero-launch-date">April 27th</span>
				</p>
			</div>

			<div class="hero-actions">
				<a href="#join" class="btn-primary">Join the Grid</a>
				<a href="#calendar" class="btn-ghost">View Calendar</a>
			</div>
		</div>

		<!-- Scroll cue -->
		<div class="scroll-cue" aria-hidden="true">
			<span>Scroll</span>
			<div class="scroll-line"></div>
		</div>
	</section>

	<!-- ══════════════════════════ STATS STRIP ══════════════════════════ -->
	<div class="stats-strip">
		{
			stats.map((s) => (
				<div class="stat-item">
					<div class="stat-value js-counter" data-target={s.value}>
						{s.value}
					</div>
					<div class="stat-label">{s.label}</div>
				</div>
			))
		}
	</div>

	<!-- ══════════════════════════ ABOUT ══════════════════════════ -->
	<section class="about" id="about">
		<div class="wrap">
			<div class="about-header reveal">
				<p class="label">Who We Are</p>
				<h2 class="section-title">
					Built for competition,<br />driven by community
				</h2>
			</div>

			<div class="about-grid reveal">
				<div class="about-story">
					<p class="section-desc">
						Founded in May 2025, Reborn Racing is dedicated to
						delivering a competitive yet enjoyable sim racing
						experience on PC.
					</p><br />
					<p class="section-desc">
						The league hosts a seasonal championship open to anyone.
					</p>
				</div>
				<div class="about-facts">
					{
						aboutFacts.map((fact) => (
							<article class="about-fact">
								<p class="about-fact-label">{fact.label}</p>
								<p class="about-fact-value">{fact.value}</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ CAR SECTION ══════════════════════════ -->
	<section class="car-section" id="car">
		<div class="wrap car-inner">
			<div class="car-info reveal">
				<p class="label car-tag">Official Car · Season 4</p>
				<h2 class="car-name">Formula RSS 3 2026</h2>
				<p class="car-desc section-desc">
					Razor-sharp through fast corners, alive under braking, and
					built for drivers who can balance aggression with precision.
				</p>
			</div>

			<div class="car-visual reveal">
				<img
					src={sfImage.src}
					alt="Ferrari SF race car"
					loading="lazy"
					decoding="async"
				/>
				<div
					class="car-features car-features--under-image"
					aria-label="Car key features"
				>
					{
						carFeatures.map((feature) => (
							<span
								class={`car-chip ${feature === "Fixed setup" ? "car-chip--highlight" : ""}`}
							>
								{feature}
							</span>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ FORMAT ══════════════════════════ -->
	<section class="format-section" id="format">
		<div class="wrap">
			<div class="format-head reveal">
				<p class="label">Championship Structure</p>
				<h2 class="section-title">Format</h2>
				<p class="format-sub section-desc">
					Single qualifying session, then Race followed by Inverted
					Grid Sprint.
				</p>
			</div>

			<div class="format-grid reveal">
				{
					format.map((item, index) => (
						<div
							class="format-card"
							style={`--card-index: ${index}`}
						>
							<div class="format-number">
								{String(index + 1).padStart(2, "0")}
							</div>
							<div class="format-content">
								<h3 class="format-phase">{item.phase}</h3>
								<div class="format-details">
									<div class="format-detail">
										<span class="detail-label">
											Duration
										</span>
										<span class="detail-value">
											{item.time}
										</span>
									</div>
									{item.distance && (
										<div class="format-detail">
											<span class="detail-label">
												Distance
											</span>
											<span class="detail-value">
												{item.distance}
											</span>
										</div>
									)}
									{item.start !== "—" && (
										<div class="format-detail">
											<span class="detail-label">
												Start Time
											</span>
											<span class="detail-value">
												{item.start}
											</span>
										</div>
									)}
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ CALENDAR ══════════════════════════ -->
	<section class="calendar-section" id="calendar">
		<div class="wrap">
			<div class="calendar-head reveal">
				<p class="label">Season 4 · 2026</p>
				<h2 class="section-title">Calendar</h2>
				<p class="calendar-sub section-desc">
					Biweekly Mondays - 10 rounds - April through July
				</p>
			</div>

			<div class="cal-table reveal">
				<div class="cal-column">
					{
						calendarLeft.map((r) => (
							<div
								class={`cal-row ${r.badge ? `cal-row--${r.badge}` : ""}`}
							>
								<div class="cal-round">{r.round}</div>
								<div class="cal-date">{r.date}</div>
								<div class="cal-flag">
									<img
										class="cal-flag-img"
										src={getFlagUrl(r.countryCode)}
										alt={`${r.country} flag`}
										loading="lazy"
										decoding="async"
										onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
									/>
									<span class="cal-flag-fallback">
										{r.countryCode}
									</span>
								</div>
								<div class="cal-circuit">
									<span class="cal-name">{r.name}</span>
									<span class="cal-country">{r.country}</span>
								</div>
								{r.badge === "opener" && (
									<span class="badge badge--red">Opener</span>
								)}
								{r.badge === "finale" && (
									<span class="badge badge--gold">
										Finale
									</span>
								)}
							</div>
						))
					}
				</div>

				<div class="cal-column">
					{
						calendarRight.map((r) => (
							<div
								class={`cal-row ${r.badge ? `cal-row--${r.badge}` : ""}`}
							>
								<div class="cal-round">{r.round}</div>
								<div class="cal-date">{r.date}</div>
								<div class="cal-flag">
									<img
										class="cal-flag-img"
										src={getFlagUrl(r.countryCode)}
										alt={`${r.country} flag`}
										loading="lazy"
										decoding="async"
										onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
									/>
									<span class="cal-flag-fallback">
										{r.countryCode}
									</span>
								</div>
								<div class="cal-circuit">
									<span class="cal-name">{r.name}</span>
									<span class="cal-country">{r.country}</span>
								</div>
								{r.badge === "opener" && (
									<span class="badge badge--red">
										Season Opener
									</span>
								)}
								{r.badge === "finale" && (
									<span class="badge badge--gold">
										Finale
									</span>
								)}
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ JOIN CTA ══════════════════════════ -->
	<section class="join-section" id="join">
		<div class="join-bg" aria-hidden="true"></div>
		<div class="wrap join-inner">
			<div class="reveal">
				<p class="label">Season 4 · Open Registration</p>
				<h2 class="join-title">
					<span class="join-title-line">Bring your pace</span>
					<span class="join-title-line">Earn your place.</span>
				</h2>
				<p class="join-sub section-desc">
					24 seats. Applications are reviewed to keep the grid
					balanced and racing standards high.
				</p>
				<div class="join-actions">
					<a
						href="https://discord.com/invite/gUXfjbfSa2"
						class="btn-ghost discord-cta"
						target="_blank"
						rel="noopener noreferrer">Join our Discord</a
					>
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ FOOTER ══════════════════════════ -->
	<footer class="footer">
		<div class="wrap footer-inner">
			<div class="footer-brand">
				Reborn <span>Racing</span>
			</div>
			<p class="footer-meta">Season 4 · 2026 · Assetto Corsa League</p>
		</div>
	</footer>
</Layout>

<style>
	/* ── Wrap ── */
	.wrap {
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 40px;
		position: relative;
		z-index: 1;
	}

	/* ── Section title ── */
	.section-title {
		font-family: var(--font-display);
		font-size: clamp(56px, 7.5vw, 100px);
		line-height: 0.93;
		letter-spacing: 0.02em;
		color: var(--white);
		margin-top: 16px;
	}
	.section-desc {
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.7;
		color: #d2d2e3;
		max-width: 100%;
	}

	/* ── Buttons ── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background: var(--red);
		color: #fff;
		font-family: var(--font-cond);
		font-weight: 700;
		font-size: 14px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 18px 40px;
		border: 2px solid var(--red);
		transition:
			background 0.2s,
			border-color 0.2s;
		position: relative;
		overflow: hidden;
	}
	.btn-primary:hover {
		background: #c5001f;
		border-color: #c5001f;
	}

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		color: var(--white);
		font-family: var(--font-cond);
		font-weight: 500;
		font-size: 14px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 18px 40px;
		border: 2px solid var(--border-mid);
		transition:
			color 0.2s,
			border-color 0.2s;
	}
	.btn-ghost:hover {
		border-color: rgba(255, 255, 255, 0.35);
	}

	.btn-large {
		padding: 22px 52px;
		font-size: 15px;
	}

	/* ════════════════ NAV ════════════════ */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(8, 8, 9, 0.94);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
	}
	.nav-inner {
		max-width: 1400px;
		margin: 0 auto;
		padding: 0 40px;
		height: 84px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 0;
	}
	.nav-brand-name {
		font-family: var(--font-display);
		font-size: 32px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		display: inline-flex;
		gap: 10px;
	}
	.nav-brand-reborn {
		color: #ffffff;
	}
	.nav-brand-racing {
		color: transparent;
		-webkit-text-stroke: 1.6px var(--red);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 40px;
	}
	.nav-links a {
		font-family: var(--font-cond);
		font-size: 19px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #d8d8e8;
		transition: color 0.2s;
	}
	.nav-links a:hover {
		color: #ffffff;
	}
	.nav-cta {
		background: var(--red) !important;
		color: #fff !important;
		padding: 10px 24px !important;
		font-size: 19px !important;
		font-weight: 700 !important;
		letter-spacing: 0.16em !important;
	}
	.nav-cta:hover {
		background: #c5001f !important;
	}

	.mobile-toggle {
		display: none;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 8px;
		/* Ensure toggle is always on top of the overlay */
		position: relative;
		z-index: 200;
	}
	.hamburger {
		display: block;
		width: 24px;
		height: 2px;
		background: #ffffff;
		position: relative;
		transition: background 0.2s;
	}
	.hamburger::before,
	.hamburger::after {
		content: "";
		position: absolute;
		width: 24px;
		height: 2px;
		background: #ffffff;
		left: 0;
		transition:
			transform 0.3s,
			top 0.3s,
			bottom 0.3s;
	}
	.hamburger::before {
		top: -8px;
	}
	.hamburger::after {
		bottom: -8px;
	}
	.mobile-toggle[aria-expanded="true"] .hamburger {
		background: transparent;
	}
	.mobile-toggle[aria-expanded="true"] .hamburger::before {
		transform: rotate(45deg);
		top: 0;
	}
	.mobile-toggle[aria-expanded="true"] .hamburger::after {
		transform: rotate(-45deg);
		bottom: 0;
	}

	/* ════════════════ HERO ════════════════ */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-top: 76px; /* nav height */
		padding-bottom: 0;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.hero-glow {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				ellipse 65% 55% at 75% 35%,
				rgba(232, 0, 45, 0.15) 0%,
				transparent 70%
			),
			radial-gradient(
				ellipse 40% 60% at 5% 85%,
				rgba(232, 0, 45, 0.07) 0%,
				transparent 60%
			),
			linear-gradient(160deg, #0d0d10 0%, #080809 100%);
	}
	.hero-stripe {
		position: absolute;
		top: 0;
		bottom: 0;
		right: 18%;
		width: 3px;
		background: linear-gradient(
			to bottom,
			transparent,
			rgba(232, 0, 45, 0.45) 30%,
			rgba(232, 0, 45, 0.45) 70%,
			transparent
		);
	}
	.hero-lines {
		position: absolute;
		inset: 0;
		background-image: repeating-linear-gradient(
			97deg,
			transparent,
			transparent 100px,
			rgba(255, 255, 255, 0.015) 101px,
			rgba(255, 255, 255, 0.015) 102px
		);
	}

	.hero-content {
		padding-bottom: 0;
	}
	.hero-eyebrow {
		margin-bottom: 28px;
		opacity: 0;
		animation: fadeUp 0.7s 0.2s ease forwards;
	}
	.hero-title {
		font-family: var(--font-display);
		line-height: 0.87;
		letter-spacing: 0.01em;
		opacity: 0;
		animation: fadeUp 0.8s 0.4s ease forwards;
	}
	.hero-title-reborn {
		display: block;
		font-size: clamp(96px, 15vw, 210px);
		color: #ffffff;
	}
	.hero-title-racing {
		display: block;
		font-size: clamp(96px, 15vw, 210px);
		-webkit-text-stroke: 2.5px var(--red);
		color: transparent;
	}
	.hero-highlight {
		margin-top: 36px;
		display: grid;
		gap: 14px;
		max-width: 760px;
		opacity: 0;
		animation: fadeUp 0.8s 0.6s ease forwards;
	}
	.hero-metrics {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 14px;
	}
	.hero-metrics span {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-cond);
		font-size: clamp(18px, 2.2vw, 28px);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #f2f2f8;
	}
	.hero-metrics .hero-metrics-champion > span {
		padding-bottom: 2px;
		border-bottom: 2px solid currentColor;
	}
	.hero-metrics span + span::before {
		content: "/";
		margin-right: 14px;
		color: var(--red);
	}
	.hero-launch-line {
		margin: 0;
		display: inline-flex;
		align-items: baseline;
		gap: 12px;
		width: fit-content;
		padding-bottom: 8px;
		position: relative;
		overflow: hidden;
		border-bottom: 2px solid var(--red-line);
		animation: launchBlip 2.1s 1.1s linear infinite;
	}
	.hero-launch-label {
		font-family: var(--font-cond);
		font-size: 16px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #f2d5dc;
	}
	.hero-launch-date {
		font-family: var(--font-cond);
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #ffffff;
	}

	.hero-actions {
		margin-top: 44px;
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
		opacity: 0;
		animation: fadeUp 0.8s 0.8s ease forwards;
	}

	.scroll-cue {
		position: absolute;
		bottom: 56px;
		right: 56px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		opacity: 0;
		animation: fadeIn 1s 1.6s ease forwards;
	}
	.scroll-cue span {
		font-family: var(--font-cond);
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--grey-light);
		writing-mode: vertical-rl;
	}
	.scroll-line {
		width: 3px;
		height: 120px;
		background: linear-gradient(to bottom, var(--grey-light), transparent);
		animation: scrollPulse 2.2s 2s ease-in-out infinite;
	}

	/* ════════════════ STATS STRIP ════════════════ */
	.stats-strip {
		position: relative;
		z-index: 1;
		display: grid;
		/* 5 equal columns on desktop */
		grid-template-columns: repeat(5, 1fr);
		max-width: 1160px;
		margin: 0 auto;
		gap: 48px;
	}
	.stat-item {
		padding: 34px 0;
		position: relative;
		text-align: center;
	}
	.stat-value {
		font-family: var(--font-display);
		font-size: clamp(52px, 5vw, 76px);
		line-height: 1;
		color: #ffffff;
	}
	.stat-label {
		font-family: var(--font-cond);
		font-size: 18px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--grey-mid);
		margin-top: 10px;
	}

	/* ════════════════ ABOUT ════════════════ */
	.hero,
	.about,
	.car-section,
	.calendar-section,
	.join-section,
	.footer {
		margin-inline: clamp(12px, 2.4vw, 28px);
	}

	.about {
		padding: 120px 0;
		background: var(--bg);
	}
	.about-header {
		margin-bottom: 64px;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		gap: 28px;
		align-items: stretch;
	}

	.about-story {
		padding: 48px;
		background: var(--surface);
		border: 1px solid var(--border);
	}

	.about-facts {
		display: grid;
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
	}
	.about-fact {
		padding: 28px 30px;
		background: var(--surface);
		transition: background 0.25s;
	}
	.about-fact:hover {
		background: var(--surface2);
	}
	.about-fact-label {
		margin: 0;
		font-family: var(--font-cond);
		font-size: 16px;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--red);
	}
	.about-fact-value {
		margin: 10px 0 0;
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: #ffffff;
	}

	/* ════════════════ CAR ════════════════ */
	.car-section {
		background: var(--surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 100px 0;
		scroll-margin-top: 200px;
	}
	.car-inner {
		display: grid;
		grid-template-columns: 1fr 1.1fr;
		gap: 80px;
		align-items: center;
	}
	.car-tag {
		margin-bottom: 20px;
	}
	.car-name {
		font-family: var(--font-display);
		font-size: clamp(48px, 5.5vw, 72px);
		line-height: 1;
		margin-bottom: 22px;
	}
	.car-desc {
		margin-bottom: 0;
	}
	.car-features {
		display: flex;
		flex-wrap: wrap;
		column-gap: 16px;
		row-gap: 10px;
	}
	.car-features--under-image {
		margin: 0;
		padding: 18px 20px;
		justify-content: center;
		border-top: none;
		background: transparent;
	}
	.car-chip {
		display: inline-flex;
		align-items: center;
		padding: 9px 14px;
		font-family: var(--font-cond);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f6f6ff;
		background: linear-gradient(
			120deg,
			rgba(255, 255, 255, 0.08),
			rgba(255, 255, 255, 0.03)
		);
		border: 1px solid rgba(255, 255, 255, 0.12);
	}
	.car-chip--highlight {
		color: #1a1100;
		background: linear-gradient(120deg, #ffd56b, #ffbe3d);
		border-color: rgba(255, 190, 61, 0.95);
		box-shadow: 0 0 0 1px rgba(255, 190, 61, 0.3);
	}
	.car-visual {
		background: transparent;
		border: none;
		padding: 0;
		display: block;
		position: relative;
		overflow: visible;
	}
	.car-visual::before {
		content: "";
		position: absolute;
		inset: 0;
		background: none;
	}
	.car-visual img {
		width: 100%;
		height: auto;
		object-fit: contain;
		position: relative;
		z-index: 1;
		border: 0;
	}

	/* ════════════════ FORMAT ════════════════ */
	.format-section {
		padding: 120px 0;
		background: linear-gradient(180deg, #0b0b0f 0%, #12121a 100%);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}
	.format-head {
		margin-bottom: 48px;
	}
	.format-sub {
		margin-top: 18px;
	}

	.format-grid {
		display: flex;
		flex-wrap: nowrap;
		gap: 20px;
		overflow-x: auto;
		padding-bottom: 6px;
		scrollbar-width: thin;
	}
	.format-card {
		background: var(--surface2);
		border: 1px solid var(--border);
		padding: 32px 24px;
		display: flex;
		flex-direction: column;
		gap: 20px;
		flex: 1 1 0;
		min-width: 280px;
		transition:
			background 0.2s,
			border-color 0.2s;
		position: relative;
		overflow: hidden;
	}
	.format-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--red);
	}
	.format-card:hover {
		background: #1f1f28;
		border-color: rgba(255, 255, 255, 0.15);
	}
	.format-number {
		font-family: var(--font-display);
		font-size: 36px;
		line-height: 1;
		color: rgba(255, 255, 255, 0.12);
	}
	.format-phase {
		font-family: var(--font-cond);
		font-size: 32px;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: #ffffff;
		margin: 0;
	}
	.format-details {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.format-detail {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 12px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.format-detail:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.detail-label {
		font-family: var(--font-cond);
		font-size: 20px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--grey-mid);
	}
	.detail-value {
		font-family: var(--font-cond);
		font-size: 26px;
		font-weight: 600;
		color: #ffffff;
	}

	/* ════════════════ CALENDAR ════════════════ */
	.calendar-section {
		padding: 120px 0;
		background: var(--bg);
	}
	.calendar-section .wrap {
		max-width: min(1580px, 97vw);
	}
	.calendar-head {
		margin-bottom: 30px;
	}
	.calendar-sub {
		margin-top: 18px;
	}

	.cal-table {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 24px;
		align-items: start;
	}

	.cal-column {
		border: 1px solid var(--border);
		background: var(--border);
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.cal-row {
		background: var(--surface);
		display: grid;
		grid-template-columns: 52px 124px 52px 1fr auto;
		gap: 0 14px;
		align-items: center;
		padding: 11px 18px;
		border-left: 3px solid transparent;
		transition:
			background 0.2s,
			border-color 0.2s;
	}
	.cal-row:hover {
		background: var(--surface2);
	}
	.cal-row--opener {
		border-left-color: var(--red);
	}
	.cal-row--finale {
		border-left-color: var(--gold);
	}

	.cal-break-mid {
		padding: 0 8px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		align-self: stretch;
	}
	.cal-break-line {
		width: 1px;
		flex: 1;
		min-height: 80px;
		background: linear-gradient(
			to bottom,
			rgba(255, 211, 77, 0),
			rgba(255, 211, 77, 0.8),
			rgba(255, 211, 77, 0)
		);
	}
	.cal-break-pill {
		padding: 14px 16px;
		border: 1px solid rgba(255, 211, 77, 0.45);
		background: linear-gradient(
			180deg,
			rgba(255, 211, 77, 0.08),
			rgba(255, 211, 77, 0.02)
		);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		min-width: 170px;
	}
	.cal-break-icon {
		font-size: 24px;
		line-height: 1;
	}
	.cal-break-title {
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #ffd34d;
		text-shadow: 0 0 10px rgba(255, 211, 77, 0.28);
		line-height: 1.05;
	}
	.cal-break-date {
		font-family: var(--font-cond);
		font-size: 15px;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f8e7b0;
	}

	.cal-round {
		font-family: var(--font-display);
		font-size: 24px;
		color: var(--grey-mid);
	}
	.cal-date {
		font-family: var(--font-cond);
		font-size: 19px;
		font-weight: 700;
		color: #c4c4d4;
		letter-spacing: 0.04em;
	}
	.cal-flag {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		justify-self: center;
		transform: translateX(-6px);
	}
	.cal-flag-img {
		width: 46px;
		height: 34px;
		object-fit: cover;
		border-radius: 2px;
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14);
	}
	.cal-flag-fallback {
		display: none;
		font-family: var(--font-cond);
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--grey-mid);
	}
	.cal-name {
		display: block;
		font-family: var(--font-cond);
		font-size: 20px;
		font-weight: 600;
		color: #ffffff;
		letter-spacing: 0.02em;
	}
	.cal-country {
		display: block;
		font-size: 15px;
		color: var(--grey-mid);
		letter-spacing: 0.06em;
		margin-top: 3px;
	}

	.badge {
		font-family: var(--font-cond);
		font-size: 13px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 4px 12px;
		border: 1px solid;
		white-space: nowrap;
	}
	.badge--red {
		color: var(--red);
		border-color: var(--red-line);
		background: var(--red-dim);
		font-weight: 700;
	}
	.badge--gold {
		color: var(--gold);
		border-color: rgba(196, 152, 38, 0.35);
		background: var(--gold-dim);
		font-weight: 700;
	}
	.badge--grey {
		color: var(--grey-mid);
		border-color: rgba(255, 255, 255, 0.14);
		background: transparent;
		font-weight: 700;
	}

	.cal-note {
		margin-top: 18px;
		font-family: var(--font-cond);
		font-size: 13px;
		letter-spacing: 0.1em;
		color: var(--grey);
	}

	/* ════════════════ JOIN CTA ════════════════ */
	.join-section {
		position: relative;
		padding: 130px 0;
		overflow: hidden;
		background: var(--bg);
		border-top: 1px solid var(--border);
	}
	.join-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				ellipse 70% 80% at 90% 50%,
				rgba(232, 0, 45, 0.1) 0%,
				transparent 65%
			),
			radial-gradient(
				ellipse 40% 50% at 10% 20%,
				rgba(232, 0, 45, 0.05) 0%,
				transparent 60%
			);
	}
	.join-inner {
		max-width: 700px;
	}
	.join-title {
		font-family: var(--font-display);
		font-size: clamp(60px, 8vw, 104px);
		line-height: 0.92;
		letter-spacing: 0.02em;
		margin-top: 18px;
		margin-bottom: 28px;
	}
	.join-title-line {
		display: block;
		white-space: nowrap;
	}
	.join-sub {
		margin-bottom: 52px;
	}
	.join-actions {
		display: flex;
		justify-content: center;
		gap: 16px;
		flex-wrap: wrap;
	}
	.join-actions .btn-ghost:hover {
		background: #5865f2;
		border-color: #5865f2;
		color: #ffffff;
	}
	.join-actions .btn-ghost {
		font-size: 18px;
		font-weight: 700;
	}
	.join-actions .discord-cta {
		position: relative;
		overflow: hidden;
		isolation: isolate;
		background: linear-gradient(
			120deg,
			#4d5ad8 0%,
			#5865f2 50%,
			#6f84ff 100%
		);
		border-color: #8ea0ff;
		color: #ffffff;
		box-shadow:
			0 0 0 1px rgba(255, 255, 255, 0.12) inset,
			0 0 0 rgba(88, 101, 242, 0.7),
			0 12px 30px rgba(88, 101, 242, 0.38);
		animation: discordPulse 2.2s ease-in-out infinite;
	}
	.join-actions .discord-cta::before {
		content: "";
		position: absolute;
		top: 0;
		left: -46%;
		width: 42%;
		height: 100%;
		background: linear-gradient(
			90deg,
			rgba(255, 255, 255, 0) 0%,
			rgba(255, 255, 255, 0.35) 50%,
			rgba(255, 255, 255, 0) 100%
		);
		transform: skewX(-22deg);
		animation: discordSweep 2.8s linear infinite;
		pointer-events: none;
	}
	.join-actions .discord-cta:hover {
		background: linear-gradient(120deg, #5b69f4 0%, #6d79ff 100%);
		border-color: #b8c5ff;
		color: #ffffff;
		transform: translateY(-2px) scale(1.02);
	}

	/* ════════════════ FOOTER ════════════════ */
	.footer {
		background: var(--surface);
		border-top: 1px solid var(--border);
		padding: 44px 0;
		position: relative;
		z-index: 1;
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer-brand {
		font-family: var(--font-display);
		font-size: 28px;
		letter-spacing: 0.04em;
	}
	.footer-brand span {
		color: var(--red);
	}
	.footer-meta {
		font-family: var(--font-cond);
		font-size: 11px;
		letter-spacing: 0.16em;
		color: var(--grey);
	}

	/* ════════════════ ANIMATIONS ════════════════ */
	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(22px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}
	@keyframes scrollPulse {
		0%,
		100% {
			opacity: 0.3;
		}
		50% {
			opacity: 1;
		}
	}
	@keyframes launchBlip {
		0%,
		42%,
		100% {
			opacity: 1;
		}
		52%,
		62% {
			opacity: 0;
		}
	}
	@keyframes discordPulse {
		0%,
		100% {
			box-shadow:
				0 0 0 1px rgba(255, 255, 255, 0.12) inset,
				0 0 0 0 rgba(88, 101, 242, 0.6),
				0 12px 30px rgba(88, 101, 242, 0.34);
		}
		50% {
			box-shadow:
				0 0 0 1px rgba(255, 255, 255, 0.16) inset,
				0 0 0 14px rgba(88, 101, 242, 0),
				0 18px 36px rgba(88, 101, 242, 0.5);
		}
	}
	@keyframes discordSweep {
		0% {
			left: -46%;
		}
		100% {
			left: 132%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-launch-line {
			animation: none;
		}
		.join-actions .discord-cta,
		.join-actions .discord-cta::before {
			animation: none;
		}
		.join-actions .discord-cta:hover {
			transform: none;
		}
	}

	/* ════════════════ RESPONSIVE ════════════════ */
	@media (max-width: 1024px) {
		.car-inner {
			grid-template-columns: 1fr;
			gap: 48px;
		}
		.about-grid {
			grid-template-columns: 1fr;
		}
		.format-grid {
			gap: 20px;
		}
		.calendar-section .wrap {
			max-width: 1160px;
		}
		.cal-table {
			grid-template-columns: 1fr;
			gap: 12px;
		}
		.cal-break-mid {
			flex-direction: row;
			gap: 14px;
			padding: 8px 0;
		}
		.cal-break-line {
			width: auto;
			height: 1px;
			min-height: 0;
			flex: 1;
			background: linear-gradient(
				to right,
				rgba(255, 211, 77, 0),
				rgba(255, 211, 77, 0.8),
				rgba(255, 211, 77, 0)
			);
		}
		.cal-break-pill {
			min-width: 0;
			padding: 10px 18px;
		}
	}

	@media (max-width: 768px) {
		.wrap {
			padding: 0 24px;
		}
		.nav-inner {
			padding: 0 24px;
			height: 76px;
		}

		/*
		 * FIX: backdrop-filter on .nav creates a new containing block for
		 * position:fixed children (per CSS spec). This traps the full-screen
		 * overlay inside the 76px nav bar. Remove it on mobile and compensate
		 * with a solid background so the overlay covers the full viewport.
		 */
		.nav {
			backdrop-filter: none;
			-webkit-backdrop-filter: none;
			background: rgba(8, 8, 9, 0.98);
		}

		.mobile-toggle {
			display: block;
		}
		.nav-links {
			position: fixed;
			inset: 0;
			background: rgba(8, 8, 9, 0.98);
			backdrop-filter: blur(15px);
			-webkit-backdrop-filter: blur(15px);
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 32px;
			transform: translateY(-100%);
			transition:
				transform 0.4s cubic-bezier(0.77, 0, 0.175, 1),
				opacity 0.4s;
			z-index: 150;
			opacity: 0;
			pointer-events: none;
		}
		.nav-links.is-open {
			transform: translateY(0);
			opacity: 1;
			pointer-events: auto;
		}
		/* Stats: 3 columns on tablet/mobile */
		.stats-strip {
			grid-template-columns: repeat(3, 1fr);
		}
		.format-grid {
			gap: 16px;
		}
