---
import Layout from "../layouts/Layout.astro";
import ServerStatus from "../components/ServerStatus.astro";
import hamVsVerImage from "../assets/imgs/hamvsver.jpg";

const title = "Reborn Racing | Season 4";
const description =
	"Reborn Racing — Season 4 launches April 27th. 24 drivers, 12 circuits, €360 prize pool. The most competitive season yet.";

const stats = [
	{ value: "30+", label: "Races Hosted" },
	{ value: "75+", label: "Registered Drivers" },
	{ value: "15+", label: "Podium Finishers" },
	{ value: "~30", label: "Reports Closed" },
	{ value: "3", label: "Seasons Completed" },
];

const aboutFacts = [
	{ label: "Founded", value: "May 2025" },
	{ label: "Platform", value: "PC" },
	{ label: "Entry", value: "Open To Everyone" },
];

const calendar = [
	{
		round: "01",
		date: "Mon 27 Apr",
		flag: "🇧🇭",
		name: "Bahrain Int. Circuit",
		country: "Sakhir, Bahrain",
		badge: "opener",
	},
	{
		round: "02",
		date: "Mon 11 May",
		flag: "🇮🇹",
		name: "Autodromo Enzo e Dino Ferrari",
		country: "Imola, Italy",
		badge: "",
	},
	{
		round: "03",
		date: "Mon 25 May",
		flag: "🇬🇧",
		name: "Silverstone Circuit",
		country: "Northamptonshire, UK",
		badge: "",
	},
	{
		round: "04",
		date: "Mon 08 Jun",
		flag: "🇦🇹",
		name: "Red Bull Ring",
		country: "Spielberg, Austria",
		badge: "",
	},
	{
		round: "05",
		date: "Mon 22 Jun",
		flag: "🇭🇺",
		name: "Hungaroring",
		country: "Mogyoród, Hungary",
		badge: "",
	},
	{
		round: "06",
		date: "Mon 06 Jul",
		flag: "🇧🇪",
		name: "Circuit de Spa-Francorchamps",
		country: "Stavelot, Belgium",
		badge: "",
	},
	{
		round: "07",
		date: "Mon 20 Jul",
		flag: "🇮🇹",
		name: "Autodromo Nazionale Monza",
		country: "Monza, Italy",
		badge: "",
	},
	{
		round: "—",
		date: "August",
		flag: "",
		name: "Summer Break",
		country: "",
		badge: "break",
	},
	{
		round: "08",
		date: "Mon 07 Sep",
		flag: "🇺🇸",
		name: "Circuit of the Americas",
		country: "Austin, Texas, USA",
		badge: "",
	},
	{
		round: "09",
		date: "Mon 21 Sep",
		flag: "🇧🇷",
		name: "Autodromo José Carlos Pace",
		country: "Interlagos, Brazil",
		badge: "",
	},
	{
		round: "10",
		date: "Mon 05 Oct",
		flag: "🇯🇵",
		name: "Suzuka International Racing Course",
		country: "Suzuka, Japan",
		badge: "",
	},
	{
		round: "11",
		date: "Mon 19 Oct",
		flag: "🇲🇽",
		name: "Autodromo Hermanos Rodríguez",
		country: "Mexico City, Mexico",
		badge: "",
	},
	{
		round: "12",
		date: "Mon 02 Nov",
		flag: "🇦🇪",
		name: "Yas Marina Circuit",
		country: "Abu Dhabi, UAE",
		badge: "finale",
	},
];

const format = [
	{ phase: "Driver Briefing", time: "5–10 min", start: "21:00" },
	{ phase: "Qualifying", time: "15 min", start: "21:10 ca." },
	{ phase: "Race", time: "45 min", start: "21:25 ca." },
];

const raceRounds = calendar.filter((r) => r.badge !== "break");
const calendarLeft = raceRounds.slice(0, 7);
const calendarRight = raceRounds.slice(7, 12);
const summerBreak = calendar.find((r) => r.badge === "break");

const prizes = [
	{ pos: "1st", amount: "125", highlight: true },
	{ pos: "2nd", amount: "80", highlight: false },
	{ pos: "3rd", amount: "60", highlight: false },
	{ pos: "4th", amount: "40", highlight: false },
	{ pos: "5th", amount: "30", highlight: false },
	{ pos: "Fair Play", amount: "25", highlight: false },
];
---

<Layout title={title} description={description}>
	<!-- ══════════════════════════ NAV ══════════════════════════ -->
	<nav class="nav">
		<div class="nav-inner">
			<a href="/" class="nav-brand">
				<span class="nav-brand-name">
					<span class="nav-brand-reborn">Reborn</span>
					<span class="nav-brand-racing">Racing</span>
				</span>
			</a>
			<div class="nav-links">
				<a href="#about">About Us</a>
				<a href="#calendar">Calendar</a>
				<a href="#prizes">Prizes</a>
				<ServerStatus />
				<a href="#join" class="nav-cta">Join Season 4</a>
			</div>
		</div>
	</nav>

	<!-- ══════════════════════════ HERO ══════════════════════════ -->
	<section class="hero">
		<div class="hero-bg" aria-hidden="true">
			<div class="hero-glow"></div>
			<div class="hero-stripe"></div>
			<!-- Speed lines -->
			<div class="hero-lines"></div>
		</div>

		<div class="hero-content wrap">
			<p class="hero-eyebrow label">
				Assetto Corsa · Sim Racing League · Season 4
			</p>

			<h1 class="hero-title">
				<span class="hero-title-reborn">Reborn</span>
				<span class="hero-title-racing">Racing</span>
			</h1>

			<div class="hero-highlight">
				<p class="hero-metrics">
					<span>24 Drivers</span>
					<span>12 Circuits</span>
					<span class="hero-metrics-champion"
						><span>1 Champion</span></span
					>
				</p>
				<p class="hero-launch-line">
					<span class="hero-launch-label">Season 4 Launches</span>
					<span class="hero-launch-date">April 27th</span>
				</p>
			</div>

			<div class="hero-actions">
				<a href="#join" class="btn-primary">Join the Grid</a>
				<a href="#calendar" class="btn-ghost">View Calendar</a>
			</div>
		</div>

		<!-- Scroll cue -->
		<div class="scroll-cue" aria-hidden="true">
			<span>Scroll</span>
			<div class="scroll-line"></div>
		</div>
	</section>

	<!-- ══════════════════════════ STATS STRIP ══════════════════════════ -->
	<div class="stats-strip">
		{
			stats.map((s) => (
				<div class="stat-item">
					<div class="stat-value js-counter" data-target={s.value}>
						{s.value}
					</div>
					<div class="stat-label">{s.label}</div>
				</div>
			))
		}
	</div>

	<!-- ══════════════════════════ ABOUT ══════════════════════════ -->
	<section class="about" id="about">
		<div class="wrap">
			<div class="about-header reveal">
				<p class="label">Who We Are</p>
				<h2 class="section-title">
					Built for competition,<br />driven by community
				</h2>
			</div>

			<div class="about-grid reveal">
				<div class="about-story">
					<p>
						Founded in May 2025, Reborn Racing is dedicated to
						delivering a competitive yet enjoyable sim racing
						experience on PC, welcoming drivers of all skill levels.
					</p>
					<p>
						The league hosts a seasonal championship open to anyone.
					</p>
				</div>
				<div class="about-facts">
					{
						aboutFacts.map((fact) => (
							<article class="about-fact">
								<p class="about-fact-label">{fact.label}</p>
								<p class="about-fact-value">{fact.value}</p>
							</article>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ CAR SECTION ══════════════════════════ -->
	<section class="car-section">
		<div class="wrap car-inner">
			<div class="car-info reveal">
				<p class="label car-tag">Official Car · Season 4</p>
				<h2 class="car-name">RSS Formula<br />Hybrid 2021</h2>
				<p class="car-desc">
					Modeled on the 2021 F1 hybrid generation. Demands precision,
					racecraft, and a deep understanding of energy deployment
					through every corner.
				</p>
				<div class="car-specs">
					<div class="spec">
						<span class="spec-k">Class</span><span class="spec-v"
							>Formula Hybrid</span
						>
					</div>
					<div class="spec">
						<span class="spec-k">Power</span><span class="spec-v"
							>~ 1000 HP</span
						>
					</div>
					<div class="spec">
						<span class="spec-k">Creator</span><span class="spec-v"
							>Race Sim Studio</span
						>
					</div>
					<div class="spec">
						<span class="spec-k">Setup</span><span class="spec-v"
							>Fixed</span
						>
					</div>
					<div class="spec">
						<span class="spec-k">Drivetrain</span><span
							class="spec-v">Hybrid / RWD</span
						>
					</div>
					<div class="spec">
						<span class="spec-k">Year</span><span class="spec-v"
							>2021</span
						>
					</div>
				</div>
			</div>

			<div class="car-visual reveal">
				<img
					src={hamVsVerImage.src}
					alt="Mercedes-AMG F1 W12 race car"
					loading="lazy"
					decoding="async"
				/>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ FORMAT ══════════════════════════ -->
	<section class="format-section">
		<div class="wrap">
			<div class="format-head reveal">
				<p class="label">Championship Structure</p>
				<h2 class="section-title">Format</h2>
				<p class="format-sub">
					Single qualifying session, followed by a 50% FIA F1 race distance.
				</p>
			</div>

			<div class="format-grid reveal">
				{
					format.map((item, index) => (
						<div
							class="format-card"
							style={`--card-index: ${index}`}
						>
							<div class="format-number">
								{String(index + 1).padStart(2, "0")}
							</div>
							<div class="format-content">
								<h3 class="format-phase">{item.phase}</h3>
								<div class="format-details">
									<div class="format-detail">
										<span class="detail-label">
											Duration
										</span>
										<span class="detail-value">
											{item.time}
										</span>
									</div>
									{item.start !== "—" && (
										<div class="format-detail">
											<span class="detail-label">
												Start Time
											</span>
											<span class="detail-value">
												{item.start}
											</span>
										</div>
									)}
								</div>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ CALENDAR ══════════════════════════ -->
	<section class="calendar-section" id="calendar">
		<div class="wrap">
			<div class="calendar-head reveal">
				<p class="label">Season 4 · 2026</p>
				<h2 class="section-title">Calendar</h2>
				<p class="calendar-sub">
					Biweekly Mondays - 12 rounds - 1-month summer break in
					August
				</p>
			</div>

			<div class="cal-table reveal">
				<div class="cal-column">
					{
						calendarLeft.map((r) => (
							<div
								class={`cal-row ${r.badge ? `cal-row--${r.badge}` : ""}`}
							>
								<div class="cal-round">{r.round}</div>
								<div class="cal-date">{r.date}</div>
								<div class="cal-flag">{r.flag}</div>
								<div class="cal-circuit">
									<span class="cal-name">{r.name}</span>
									<span class="cal-country">{r.country}</span>
								</div>
								{r.badge === "opener" && (
									<span class="badge badge--red">
										Season Opener
									</span>
								)}
								{r.badge === "finale" && (
									<span class="badge badge--gold">
										Season Finale
									</span>
								)}
							</div>
						))
					}
				</div>

				{
					summerBreak && (
						<div class="cal-break-mid">
							<div class="cal-break-line" aria-hidden="true" />
							<div class="cal-break-pill">
								<span class="cal-break-icon">☀</span>
								<span class="cal-break-title">
									{summerBreak.name}
								</span>
								<span class="cal-break-date">
									{summerBreak.date}
								</span>
							</div>
							<div class="cal-break-line" aria-hidden="true" />
						</div>
					)
				}

				<div class="cal-column">
					{
						calendarRight.map((r) => (
							<div
								class={`cal-row ${r.badge ? `cal-row--${r.badge}` : ""}`}
							>
								<div class="cal-round">{r.round}</div>
								<div class="cal-date">{r.date}</div>
								<div class="cal-flag">{r.flag}</div>
								<div class="cal-circuit">
									<span class="cal-name">{r.name}</span>
									<span class="cal-country">{r.country}</span>
								</div>
								{r.badge === "opener" && (
									<span class="badge badge--red">
										Season Opener
									</span>
								)}
								{r.badge === "finale" && (
									<span class="badge badge--gold">
										Season Finale
									</span>
								)}
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ PRIZES ══════════════════════════ -->
	<section class="prizes-section" id="prizes">
		<div class="wrap">
			<div class="prizes-head reveal">
				<p class="label">Championship Rewards</p>
				<h2 class="section-title">Prize Pool</h2>
			</div>

			<div class="prizes-grid reveal">
				{
					prizes.map((p) => (
						<div
							class={`prize-card ${p.highlight ? "prize-card--gold" : ""}`}
						>
							<div class="prize-pos">{p.pos}</div>
							<div class="prize-amount">€{p.amount}</div>
						</div>
					))
				}
			</div>

			<div class="prize-total reveal">
				<span class="prize-total-label">Total Prize Pool</span>
				<span class="prize-total-value">€ 360</span>
			</div>

			<div class="prize-note reveal">
				<p class="prize-note-title">100% Prize Fund Policy</p>
				<p>
					<strong
						>Every euro of entry fees goes straight to the prize
						pool.</strong
					>
				</p>
				<p class="prize-note-line">
					Entry fee is €15 per driver, and with 24 drivers the full
					€360 is paid back out as rewards.
				</p>
				<p>No admin cuts. No hidden deductions.</p>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ JOIN CTA ══════════════════════════ -->
	<section class="join-section" id="join">
		<div class="join-bg" aria-hidden="true"></div>
		<div class="wrap join-inner">
			<div class="reveal">
				<p class="label">Season 4 · Open Registration</p>
				<h2 class="join-title">
					Bring your pace.<br />Earn your place.
				</h2>
				<p class="join-sub">
					24 seats. Applications are reviewed to keep the grid
					balanced and racing standards high. Entry fee secures your
					spot and feeds the prize pool.
				</p>
				<div class="join-actions">
					<a
						href="https://discord.com/invite/gUXfjbfSa2"
						class="btn-ghost"
						target="_blank"
						rel="noopener noreferrer">Join our Discord</a
					>
				</div>
			</div>
		</div>
	</section>

	<!-- ══════════════════════════ FOOTER ══════════════════════════ -->
	<footer class="footer">
		<div class="wrap footer-inner">
			<div class="footer-brand">
				Reborn <span>Racing</span>
			</div>
			<p class="footer-meta">Season 4 · 2026 · Assetto Corsa League</p>
		</div>
	</footer>
</Layout>

<style>
	/* ── Wrap ── */
	.wrap {
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 40px;
		position: relative;
		z-index: 1;
	}

	/* ── Section title ── */
	.section-title {
		font-family: var(--font-display);
		font-size: clamp(56px, 7.5vw, 100px);
		line-height: 0.93;
		letter-spacing: 0.02em;
		color: var(--white);
		margin-top: 16px;
	}

	/* ── Buttons ── */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background: var(--red);
		color: #fff;
		font-family: var(--font-cond);
		font-weight: 700;
		font-size: 14px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 18px 40px;
		border: 2px solid var(--red);
		transition:
			background 0.2s,
			border-color 0.2s;
		position: relative;
		overflow: hidden;
	}
	.btn-primary:hover {
		background: #c5001f;
		border-color: #c5001f;
	}

	.btn-ghost {
		display: inline-flex;
		align-items: center;
		color: var(--white);
		font-family: var(--font-cond);
		font-weight: 500;
		font-size: 14px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 18px 40px;
		border: 2px solid var(--border-mid);
		transition:
			color 0.2s,
			border-color 0.2s;
	}
	.btn-ghost:hover {
		border-color: rgba(255, 255, 255, 0.35);
	}

	.btn-large {
		padding: 22px 52px;
		font-size: 15px;
	}

	/* ════════════════ NAV ════════════════ */
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(8, 8, 9, 0.94);
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
	}
	.nav-inner {
		max-width: 1160px;
		margin: 0 auto;
		padding: 0 40px;
		height: 84px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.nav-brand {
		display: flex;
		align-items: center;
		gap: 0;
	}
	.nav-brand-name {
		font-family: var(--font-display);
		font-size: 32px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		display: inline-flex;
		gap: 10px;
	}
	.nav-brand-reborn {
		color: #ffffff;
	}
	.nav-brand-racing {
		color: transparent;
		-webkit-text-stroke: 1.6px var(--red);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 40px;
	}
	.nav-links a {
		font-family: var(--font-cond);
		font-size: 19px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #d8d8e8;
		transition: color 0.2s;
	}
	.nav-links a:hover {
		color: #ffffff;
	}
	.nav-cta {
		background: var(--red) !important;
		color: #fff !important;
		padding: 10px 24px !important;
		font-size: 19px !important;
		font-weight: 700 !important;
		letter-spacing: 0.16em !important;
	}
	.nav-cta:hover {
		background: #c5001f !important;
	}

	/* ════════════════ HERO ════════════════ */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		padding-top: 76px; /* nav height */
		padding-bottom: 0;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.hero-glow {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				ellipse 65% 55% at 75% 35%,
				rgba(232, 0, 45, 0.15) 0%,
				transparent 70%
			),
			radial-gradient(
				ellipse 40% 60% at 5% 85%,
				rgba(232, 0, 45, 0.07) 0%,
				transparent 60%
			),
			linear-gradient(160deg, #0d0d10 0%, #080809 100%);
	}
	.hero-stripe {
		position: absolute;
		top: 0;
		bottom: 0;
		right: 18%;
		width: 3px;
		background: linear-gradient(
			to bottom,
			transparent,
			rgba(232, 0, 45, 0.45) 30%,
			rgba(232, 0, 45, 0.45) 70%,
			transparent
		);
	}
	.hero-lines {
		position: absolute;
		inset: 0;
		background-image: repeating-linear-gradient(
			97deg,
			transparent,
			transparent 100px,
			rgba(255, 255, 255, 0.015) 101px,
			rgba(255, 255, 255, 0.015) 102px
		);
	}

	.hero-content {
		padding-bottom: 0;
	}
	.hero-eyebrow {
		margin-bottom: 28px;
		opacity: 0;
		animation: fadeUp 0.7s 0.2s ease forwards;
	}
	.hero-title {
		font-family: var(--font-display);
		line-height: 0.87;
		letter-spacing: 0.01em;
		opacity: 0;
		animation: fadeUp 0.8s 0.4s ease forwards;
	}
	.hero-title-reborn {
		display: block;
		font-size: clamp(96px, 15vw, 210px);
		color: #ffffff;
	}
	.hero-title-racing {
		display: block;
		font-size: clamp(96px, 15vw, 210px);
		-webkit-text-stroke: 2.5px var(--red);
		color: transparent;
	}
	.hero-highlight {
		margin-top: 36px;
		display: grid;
		gap: 14px;
		max-width: 760px;
		opacity: 0;
		animation: fadeUp 0.8s 0.6s ease forwards;
	}
	.hero-metrics {
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 14px;
	}
	.hero-metrics span {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-cond);
		font-size: clamp(18px, 2.2vw, 28px);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #f2f2f8;
	}
	.hero-metrics .hero-metrics-champion > span {
		padding-bottom: 2px;
		border-bottom: 2px solid currentColor;
	}
	.hero-metrics span + span::before {
		content: "/";
		margin-right: 14px;
		color: var(--red);
	}
	.hero-launch-line {
		margin: 0;
		display: inline-flex;
		align-items: baseline;
		gap: 12px;
		width: fit-content;
		padding-bottom: 8px;
		position: relative;
		overflow: hidden;
		border-bottom: 2px solid var(--red-line);
		animation: launchBlip 2.1s 1.1s linear infinite;
	}
	.hero-launch-label {
		font-family: var(--font-cond);
		font-size: 16px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #f2d5dc;
	}
	.hero-launch-date {
		font-family: var(--font-cond);
		font-size: clamp(30px, 4vw, 44px);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #ffffff;
	}

	.hero-actions {
		margin-top: 44px;
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
		opacity: 0;
		animation: fadeUp 0.8s 0.8s ease forwards;
	}

	.scroll-cue {
		position: absolute;
		bottom: 56px;
		right: 56px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		opacity: 0;
		animation: fadeIn 1s 1.6s ease forwards;
	}
	.scroll-cue span {
		font-family: var(--font-cond);
		font-size: 15px;
		font-weight: 700;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--grey-light);
		writing-mode: vertical-rl;
	}
	.scroll-line {
		width: 3px;
		height: 120px;
		background: linear-gradient(to bottom, var(--grey-light), transparent);
		animation: scrollPulse 2.2s 2s ease-in-out infinite;
	}

	/* ════════════════ STATS STRIP ════════════════ */
	.stats-strip {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 1fr;
		max-width: 1160px;
		margin: 0 auto;
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		background: transparent;
	}
	.stat-item {
		padding: 34px 40px;
		position: relative;
		overflow: hidden;
		text-align: center;
		background: transparent;
	}
	.stat-item + .stat-item {
		border-top: none;
	}
	.stat-value {
		font-family: var(--font-display);
		font-size: clamp(52px, 5vw, 76px);
		line-height: 1;
		color: #ffffff;
	}
	.stat-label {
		font-family: var(--font-cond);
		font-size: 18px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--grey-mid);
		margin-top: 10px;
	}

	/* ════════════════ ABOUT ════════════════ */
	.hero,
	.about,
	.car-section,
	.calendar-section,
	.prizes-section,
	.join-section,
	.footer {
		margin-inline: clamp(12px, 2.4vw, 28px);
	}

	.about {
		padding: 120px 0;
		background: var(--bg);
	}
	.about-header {
		margin-bottom: 64px;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.25fr 1fr;
		gap: 28px;
		align-items: stretch;
	}

	.about-story {
		padding: 48px;
		background: var(--surface);
		border: 1px solid var(--border);
	}

	.about-story p {
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.7;
		color: #d2d2e3;
		max-width: 44ch;
	}

	.about-facts {
		display: grid;
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
	}
	.about-fact {
		padding: 28px 30px;
		background: var(--surface);
		transition: background 0.25s;
	}
	.about-fact:hover {
		background: var(--surface2);
	}
	.about-fact-label {
		margin: 0;
		font-family: var(--font-cond);
		font-size: 16px;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--red);
	}
	.about-fact-value {
		margin: 10px 0 0;
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: #ffffff;
	}

	/* ════════════════ CAR ════════════════ */
	.car-section {
		background: var(--surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
		padding: 100px 0;
	}
	.car-inner {
		display: grid;
		grid-template-columns: 1fr 1.1fr;
		gap: 80px;
		align-items: center;
	}
	.car-tag {
		margin-bottom: 20px;
	}
	.car-name {
		font-family: var(--font-display);
		font-size: clamp(48px, 5.5vw, 72px);
		line-height: 1;
		margin-bottom: 22px;
	}
	.car-desc {
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.7;
		color: #d2d2e3;
		max-width: 44ch;
		margin-bottom: 36px;
	}
	.car-specs {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
	}
	.spec {
		background: var(--surface2);
		padding: 14px 18px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.spec-k {
		font-family: var(--font-cond);
		font-size: 15px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--grey-mid);
	}
	.spec-v {
		font-family: var(--font-cond);
		font-size: 18px;
		font-weight: 600;
		color: #ffffff;
	}
	.car-visual {
		background: var(--surface2);
		border: 1px solid var(--border);
		padding: 0;
		display: block;
		position: relative;
		overflow: hidden;
	}
	.car-visual::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse at center,
			rgba(232, 0, 45, 0.07) 0%,
			transparent 70%
		);
	}
	.car-visual img {
		width: 100%;
		height: auto;
		object-fit: contain;
		position: relative;
		z-index: 1;
		border: 0;
	}

	/* ════════════════ FORMAT ════════════════ */
	.format-section {
		padding: 120px 0;
		background: linear-gradient(180deg, #0b0b0f 0%, #12121a 100%);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}
	.format-head {
		margin-bottom: 48px;
	}
	.format-sub {
		margin-top: 18px;
		font-size: clamp(18px, 2vw, 24px);
		line-height: 1.45;
		color: #d2d2e3;
		max-width: 52ch;
	}

	.format-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}
	.format-card {
		background: var(--surface2);
		border: 1px solid var(--border);
		padding: 32px 24px;
		display: flex;
		flex-direction: column;
		gap: 20px;
		transition:
			background 0.2s,
			border-color 0.2s;
		position: relative;
		overflow: hidden;
	}
	.format-card::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: var(--red);
	}
	.format-card:hover {
		background: #1f1f28;
		border-color: rgba(255, 255, 255, 0.15);
	}
	.format-number {
		font-family: var(--font-display);
		font-size: 36px;
		line-height: 1;
		color: rgba(255, 255, 255, 0.12);
	}
	.format-phase {
		font-family: var(--font-cond);
		font-size: 32px;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: #ffffff;
		margin: 0;
	}
	.format-details {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.format-detail {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-bottom: 12px;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
	}
	.format-detail:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.detail-label {
		font-family: var(--font-cond);
		font-size: 20px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--grey-mid);
	}
	.detail-value {
		font-family: var(--font-cond);
		font-size: 26px;
		font-weight: 600;
		color: #ffffff;
	}

	/* ════════════════ CALENDAR ════════════════ */
	.calendar-section {
		padding: 120px 0;
		background: var(--bg);
	}
	.calendar-section .wrap {
		max-width: min(1580px, 97vw);
	}
	.calendar-head {
		margin-bottom: 30px;
	}
	.calendar-sub {
		margin-top: 18px;
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.5;
		color: #d2d2e3;
		max-width: 50ch;
	}

	.cal-table {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		gap: 24px;
		align-items: start;
	}

	.cal-column {
		border: 1px solid var(--border);
		background: var(--border);
		display: flex;
		flex-direction: column;
		gap: 1px;
	}
	.cal-row {
		background: var(--surface);
		display: grid;
		grid-template-columns: 52px 124px 40px 1fr auto;
		gap: 0 14px;
		align-items: center;
		padding: 11px 18px;
		border-left: 3px solid transparent;
		transition:
			background 0.2s,
			border-color 0.2s;
	}
	.cal-row:hover {
		background: var(--surface2);
	}
	.cal-row--opener {
		border-left-color: var(--red);
	}
	.cal-row--finale {
		border-left-color: var(--gold);
	}

	.cal-break-mid {
		padding: 0 8px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		align-self: stretch;
	}
	.cal-break-line {
		width: 1px;
		flex: 1;
		min-height: 80px;
		background: linear-gradient(
			to bottom,
			rgba(255, 211, 77, 0),
			rgba(255, 211, 77, 0.8),
			rgba(255, 211, 77, 0)
		);
	}
	.cal-break-pill {
		padding: 14px 16px;
		border: 1px solid rgba(255, 211, 77, 0.45);
		background: linear-gradient(
			180deg,
			rgba(255, 211, 77, 0.08),
			rgba(255, 211, 77, 0.02)
		);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2px;
		min-width: 170px;
	}
	.cal-break-icon {
		font-size: 24px;
		line-height: 1;
	}
	.cal-break-title {
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #ffd34d;
		text-shadow: 0 0 10px rgba(255, 211, 77, 0.28);
		line-height: 1.05;
	}
	.cal-break-date {
		font-family: var(--font-cond);
		font-size: 15px;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f8e7b0;
	}

	.cal-round {
		font-family: var(--font-display);
		font-size: 24px;
		color: var(--grey-mid);
	}
	.cal-date {
		font-family: var(--font-cond);
		font-size: 19px;
		font-weight: 700;
		color: #c4c4d4;
		letter-spacing: 0.04em;
	}
	.cal-flag {
		font-size: 30px;
	}
	.cal-name {
		display: block;
		font-family: var(--font-cond);
		font-size: 20px;
		font-weight: 600;
		color: #ffffff;
		letter-spacing: 0.02em;
	}
	.cal-country {
		display: block;
		font-size: 15px;
		color: var(--grey-mid);
		letter-spacing: 0.06em;
		margin-top: 3px;
	}

	.badge {
		font-family: var(--font-cond);
		font-size: 13px;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		padding: 4px 12px;
		border: 1px solid;
		white-space: nowrap;
	}
	.badge--red {
		color: var(--red);
		border-color: var(--red-line);
		background: var(--red-dim);
		font-weight: 700;
	}
	.badge--gold {
		color: var(--gold);
		border-color: rgba(196, 152, 38, 0.35);
		background: var(--gold-dim);
		font-weight: 700;
	}
	.badge--grey {
		color: var(--grey-mid);
		border-color: rgba(255, 255, 255, 0.14);
		background: transparent;
		font-weight: 700;
	}

	.cal-note {
		margin-top: 18px;
		font-family: var(--font-cond);
		font-size: 13px;
		letter-spacing: 0.1em;
		color: var(--grey);
	}

	/* ════════════════ PRIZES ════════════════ */
	.prizes-section {
		padding: 120px 0;
		background: var(--surface);
		border-top: 1px solid var(--border);
	}
	.prizes-head {
		margin-bottom: 56px;
	}

	.prizes-grid {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 1px;
		background: var(--border);
		border: 1px solid var(--border);
	}
	.prize-card {
		background: var(--surface2);
		padding: 36px 24px;
		transition: background 0.2s;
		position: relative;
		overflow: hidden;
	}
	.prize-card:hover {
		background: #1c1c24;
	}
	.prize-card--gold {
		background: var(--gold-dim);
	}
	.prize-card--gold:hover {
		background: rgba(196, 152, 38, 0.18);
	}
	.prize-pos {
		font-family: var(--font-cond);
		font-size: 13px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--grey-mid);
		margin-bottom: 16px;
	}
	.prize-card--gold .prize-pos {
		color: var(--gold);
	}
	.prize-amount {
		font-family: var(--font-display);
		font-size: clamp(40px, 3.5vw, 52px);
		line-height: 1;
		color: #ffffff;
	}
	.prize-card--gold .prize-amount {
		color: var(--gold);
	}

	.prize-total {
		background: var(--red);
		padding: 28px 36px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 20px;
	}
	.prize-total-label {
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 700;
		letter-spacing: 0.25em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.85);
	}
	.prize-total-value {
		font-family: var(--font-display);
		font-size: 48px;
		color: #fff;
	}

	.prize-note {
		margin-top: 24px;
		padding: 28px 32px;
		background: linear-gradient(
			110deg,
			rgba(232, 0, 45, 0.16),
			rgba(232, 0, 45, 0.04)
		);
		border: 1px solid var(--red-line);
	}
	.prize-note .prize-note-title {
		font-family: var(--font-cond);
		font-size: 22px;
		font-weight: 700;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: #61e58a;
		margin-bottom: 12px;
	}
	.prize-note p {
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.7;
		color: #d2d2e3;
		max-width: 44ch;
	}
	.prize-note .prize-note-line {
		white-space: normal;
		max-width: none;
	}
	.prize-note strong {
		color: #ffffff;
		font-weight: 700;
	}

	/* ════════════════ JOIN CTA ════════════════ */
	.join-section {
		position: relative;
		padding: 130px 0;
		overflow: hidden;
		background: var(--bg);
		border-top: 1px solid var(--border);
	}
	.join-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(
				ellipse 70% 80% at 90% 50%,
				rgba(232, 0, 45, 0.1) 0%,
				transparent 65%
			),
			radial-gradient(
				ellipse 40% 50% at 10% 20%,
				rgba(232, 0, 45, 0.05) 0%,
				transparent 60%
			);
	}
	.join-inner {
		max-width: 700px;
	}
	.join-title {
		font-family: var(--font-display);
		font-size: clamp(60px, 8vw, 104px);
		line-height: 0.92;
		letter-spacing: 0.02em;
		margin-top: 18px;
		margin-bottom: 28px;
	}
	.join-sub {
		font-size: clamp(18px, 2.3vw, 24px);
		line-height: 1.7;
		color: #d2d2e3;
		max-width: 44ch;
		margin-bottom: 52px;
	}
	.join-actions {
		display: flex;
		justify-content: center;
		gap: 16px;
		flex-wrap: wrap;
	}
	.join-actions .btn-ghost:hover {
		background: #5865f2;
		border-color: #5865f2;
		color: #ffffff;
	}
	.join-actions .btn-ghost {
		font-size: 18px;
		font-weight: 700;
	}

	/* ════════════════ FOOTER ════════════════ */
	.footer {
		background: var(--surface);
		border-top: 1px solid var(--border);
		padding: 44px 0;
		position: relative;
		z-index: 1;
	}
	.footer-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer-brand {
		font-family: var(--font-display);
		font-size: 28px;
		letter-spacing: 0.04em;
	}
	.footer-brand span {
		color: var(--red);
	}
	.footer-meta {
		font-family: var(--font-cond);
		font-size: 11px;
		letter-spacing: 0.16em;
		color: var(--grey);
	}

	/* ════════════════ ANIMATIONS ════════════════ */
	@keyframes fadeUp {
		from {
			opacity: 0;
			transform: translateY(22px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}
	@keyframes scrollPulse {
		0%,
		100% {
			opacity: 0.3;
		}
		50% {
			opacity: 1;
		}
	}
	@keyframes launchBlip {
		0%,
		42%,
		100% {
			opacity: 1;
		}
		52%,
		62% {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-launch-line {
			animation: none;
		}
	}

	/* ════════════════ RESPONSIVE ════════════════ */
	@media (max-width: 1024px) {
		.car-inner {
			grid-template-columns: 1fr;
			gap: 48px;
		}
		.about-grid {
			grid-template-columns: 1fr;
		}
		.format-grid {
			grid-template-columns: 1fr 1fr;
		}
		.calendar-section .wrap {
			max-width: 1160px;
		}
		.cal-table {
			grid-template-columns: 1fr;
			gap: 12px;
		}
		.cal-break-mid {
			flex-direction: row;
			gap: 14px;
			padding: 8px 0;
		}
		.cal-break-line {
			width: auto;
			height: 1px;
			min-height: 0;
			flex: 1;
			background: linear-gradient(
				to right,
				rgba(255, 211, 77, 0),
				rgba(255, 211, 77, 0.8),
				rgba(255, 211, 77, 0)
			);
		}
		.cal-break-pill {
			min-width: 0;
			padding: 10px 18px;
		}
		.prizes-grid {
